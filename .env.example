# ─────────────────────────────────────────────────────────
# Mist Min Data Rate Automation — environment variables
# ─────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to source control.

# Your Mist API token (from Mist Dashboard → My Profile → API Tokens)
MIST_API_TOKEN=your_mist_api_token_here

# Your Mist Organisation ID (Dashboard → Org → Settings → Org ID)
MIST_ORG_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# API host — choose the one matching your Mist cloud region:
#   api.mist.com        (US / Global)
#   api.eu.mist.com     (EU)
#   api.gc1.mist.com    (Asia-Pacific)
MIST_API_HOST=api.mist.com

# (Optional) restrict to a single SSID — leave blank to configure all WLANs
TARGET_SSID=
